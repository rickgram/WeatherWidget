<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="0dp">

    <!-- Current weather (left section) — tap to refresh -->
    <LinearLayout
        android:id="@+id/current_section"
        android:layout_width="95dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingEnd="4dp"
        android:clickable="true">

        <ImageView
            android:id="@+id/current_icon"
            android:layout_width="@dimen/current_icon_size"
            android:layout_height="@dimen/current_icon_size"
            android:contentDescription="Current weather"
            android:src="@drawable/ic_weather_clear" />

        <ImageView
            android:id="@+id/current_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:contentDescription="Temperature" />

    </LinearLayout>

    <!-- Divider wrapper -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <ImageView
            android:layout_width="1dp"
            android:layout_height="56dp"
            android:background="@color/widget_divider"
            android:contentDescription="divider" />

    </LinearLayout>

    <!-- Forecast (right section) — tap to open weather app -->
    <LinearLayout
        android:id="@+id/forecast_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:clickable="true">

        <!-- Day 1 (Today) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/day1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 1" />

            <ImageView
                android:id="@+id/day1_icon"
                android:layout_width="@dimen/forecast_icon_size"
                android:layout_height="@dimen/forecast_icon_size"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 1 weather"
                android:src="@drawable/ic_weather_clear" />

            <ImageView
                android:id="@+id/day1_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 1 high" />

            <ImageView
                android:id="@+id/day1_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 1 low" />

        </LinearLayout>

        <!-- Day 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/day2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 2" />

            <ImageView
                android:id="@+id/day2_icon"
                android:layout_width="@dimen/forecast_icon_size"
                android:layout_height="@dimen/forecast_icon_size"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 2 weather"
                android:src="@drawable/ic_weather_clear" />

            <ImageView
                android:id="@+id/day2_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 2 high" />

            <ImageView
                android:id="@+id/day2_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 2 low" />

        </LinearLayout>

        <!-- Day 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/day3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 3" />

            <ImageView
                android:id="@+id/day3_icon"
                android:layout_width="@dimen/forecast_icon_size"
                android:layout_height="@dimen/forecast_icon_size"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 3 weather"
                android:src="@drawable/ic_weather_clear" />

            <ImageView
                android:id="@+id/day3_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 3 high" />

            <ImageView
                android:id="@+id/day3_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 3 low" />

        </LinearLayout>

        <!-- Day 4 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/day4_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 4" />

            <ImageView
                android:id="@+id/day4_icon"
                android:layout_width="@dimen/forecast_icon_size"
                android:layout_height="@dimen/forecast_icon_size"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 4 weather"
                android:src="@drawable/ic_weather_clear" />

            <ImageView
                android:id="@+id/day4_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:contentDescription="Day 4 high" />

            <ImageView
                android:id="@+id/day4_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Day 4 low" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
